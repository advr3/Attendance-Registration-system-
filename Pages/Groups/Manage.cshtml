@page
@model personal_attendanse_system.Pages.Groups.ManageModel
@{
    ViewData["Title"] = "Manage Groups page";
}

<div class="container mt-4">
    <partial name="_StatusMessage" model="Model.StatusMessage" />
    @if (!Model.Groups.Any())
    {
        <div class="alert alert-info" role="alert">
            No groups found.
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">Manage Groups</h2>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createGroupModal">
            New Group
        </button>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Current Groups</h4>
                    <form asp-page-handler="Search" method="get">
                        <div class="input-group">
                            <input type="text" name="searchQuery" class="form-control" placeholder="Search groups by name..." value="@Model.SearchQuery" />
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-body">
                    
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="groupsTable">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>Group Name</th>
                                        <th>Public</th>
                                        <th>Created On</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in Model.Groups)
                                    {
                                        <tr id="group-row-@group.Id">
                                            <td>@group.name</td>
                                            <td>
                                                @if (group.isPublic)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success">Public</i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger">Private</i>
                                                }
                                            </td>
                                            <td>@group.creationDate.ToShortDateString()</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-warning mb-1 edit-group-btn" data-bs-toggle="modal" data-bs-target="#editGroupModal"
                                                        data-group-id="@group.Id" data-group-name="@group.name" data-is-public="@group.isPublic.ToString().ToLower()">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-danger mb-1 delete-group-btn" data-group-id="@group.Id" data-group-name="@group.name">
                                                    <i class="bi bi-trash-fill"></i> Delete
                                                </button>
                                                <a asp-page="/Group/ManageMembers" asp-route-GroupId="@group.Id" class="btn btn-sm btn-primary mb-1">
                                                    Manage Members
                                                </a>
                                                <a asp-page="/Group/ManageStaffs" asp-route-GroupId="@group.Id" class="btn btn-sm btn-success mb-1">
                                                    Manage Staffs
                                                </a>
                                                <a asp-page="/Group/Index" asp-route-id="@group.Id" class="btn btn-sm btn-outline-info mb-1">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createGroupModalLabel">Create New Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createGroupForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="create-group-name" class="form-label">Group Name</label>
                        <input type="text" id="create-group-name" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="create-group-description" class="form-label">Group Description</label>
                        <input type="text" id="create-group-description" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input type="checkbox" id="create-is-public" name="IsPublic" class="form-check-input" />
                        <label for="create-is-public" class="form-check-label">Make group public</label>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input type="checkbox" id="create-limit-link-active-time" name="IsPublic" class="form-check-input" />
                        <label for="create-limit-link-active-time" class="form-check-label">Limit Link Active/Creation times</label>
                    </div>
                    <div class="mb-3">
                                <label for="days" class="form-label">Days of the Week</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Sunday" />
                                        <label class="form-check-label">Sun</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Monday" />
                                        <label class="form-check-label">Mon</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Tuesday" />
                                        <label class="form-check-label">Tue</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Wednesday" />
                                        <label class="form-check-label">Wed</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Thursday" />
                                        <label class="form-check-label">Thu</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Friday" />
                                        <label class="form-check-label">Fri</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="Days" value="Saturday" />
                                        <label class="form-check-label">Sat</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="start" class="form-label">Start Time</label>
                                <input type="time" class="form-control" name="startTime" />
                            </div>
                            <div class="mb-3">
                                <label for="end" class="form-label">End Time</label>
                                <input type="time" class="form-control" name="endTime" />
                            </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Group</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editGroupModal" tabindex="-1" aria-labelledby="editGroupModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editGroupModalLabel">Edit Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editGroupForm">
                <input type="hidden" id="edit-group-id" name="Id" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="edit-group-name" class="form-label">Group Name</label>
                        <input type="text" id="edit-group-name" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input type="checkbox" id="edit-is-public" name="IsPublic" class="form-check-input" />
                        <label for="edit-is-public" class="form-check-label">Make group public</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showStatusMessage(message, isSuccess) {
            const statusMessageDiv = document.querySelector('div[role="alert"]');
            if (statusMessageDiv) {
                statusMessageDiv.className = `alert ${isSuccess ? 'alert-success' : 'alert-danger'} show`;
                statusMessageDiv.textContent = message;
            } else {
                const container = document.querySelector('.container.mt-4');
                const newStatusDiv = document.createElement('div');
                newStatusDiv.className = `alert ${isSuccess ? 'alert-success' : 'alert-danger'} show fade`;
                newStatusDiv.setAttribute('role', 'alert');
                newStatusDiv.textContent = message;
                container.prepend(newStatusDiv);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Edit Modal Handler
            const editModal = document.getElementById('editGroupModal');
            if (editModal) {
                editModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const groupId = button.getAttribute('data-group-id');
                    const groupName = button.getAttribute('data-group-name');
                    const isPublic = button.getAttribute('data-is-public') === 'true';

                    document.getElementById('edit-group-id').value = groupId;
                    document.getElementById('edit-group-name').value = groupName;
                    document.getElementById('edit-is-public').checked = isPublic;
                });
            }

            // Create Form Submission
            const createForm = document.getElementById('createGroupForm');
            if (createForm) {
                createForm.addEventListener('submit', async function (event) {
                    event.preventDefault();

                    const payload = {
                        Name: document.getElementById('create-group-name').value,
                        Description: document.getElementById('create-group-description').value,
                        IsPublic: document.getElementById('create-is-public').checked,
                        LimitLinkActiveTime: document.getElementById('create-limit-link-active-time').checked,
                        days: Array.from(createForm.querySelectorAll('input[name="Days"]:checked')).map(cb => cb.value),
                        startTime: createForm.querySelector('input[name="startTime"]').value,
                        endTime: createForm.querySelector('input[name="endTime"]').value
                    };

                    try {
                        console.log("start create request");
                        const response = await fetch('?handler=Create', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: JSON.stringify(payload)
                        });
                        console.log("resive request response");
                        const result = await response.json();
                        if (result.success) {
                            showStatusMessage(result.message, true);

                            // Dynamically add the new group row
                            const tableBody = document.querySelector('#groupsTable tbody');
                            if (tableBody) {
                                const newRow = document.createElement('tr');
                                newRow.id = `group-row-${result.group.id}`;
                                const isPublicIcon = result.group.isPublic
                                    ? '<i class="bi bi-check-circle-fill text-success">Public</i>'
                                    : '<i class="bi bi-x-circle-fill text-danger">Private</i>';

                                newRow.innerHTML = `
                                            <td>${result.group.name}</td>
                                            <td>${isPublicIcon}</td>
                                            <td>${result.group.creationDate}</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-warning mb-1 edit-group-btn" data-bs-toggle="modal" data-bs-target="#editGroupModal"
                                                        data-group-id="${result.group.id}" data-group-name="${result.group.name}" data-is-public="${result.group.isPublic}">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-danger mb-1 delete-group-btn" data-group-id="${result.group.id}" data-group-name="${result.group.name}">
                                                    <i class="bi bi-trash-fill"></i> Delete
                                                </button>
                                                <a href="/Group/ManageMembers/${result.group.id}" class="btn btn-sm btn-primary mb-1">
                                                    Manage Members
                                                </a>
                                                <a href="/Group/ManageStaffs/${result.group.id}" class="btn btn-sm btn-success mb-1">
                                                    Manage Staffs
                                                </a>
                                                <a href="/Group/${result.group.id}" class="btn btn-sm btn-outline-info mb-1">View</a>
                                            </td>
                                        `;
                                tableBody.appendChild(newRow);

                                // Clear the form and close the modal
                                createForm.reset();
                                bootstrap.Modal.getInstance(document.getElementById('createGroupModal')).hide();
                            }
                        } else {
                            showStatusMessage(result.message, false);
                        }
                    } catch (error) {
                        showStatusMessage("An error occurred. Please try again.", false);
                        console.error('Error creating group:', error);
                    }
                });
            }

            // Edit Form Submission
            const editForm = document.getElementById('editGroupForm');
            if (editForm) {
                editForm.addEventListener('submit', async function (event) {
                    event.preventDefault();

                    const payload = {
                        Id: document.getElementById('edit-group-id').value,
                        Name: document.getElementById('edit-group-name').value,
                        IsPublic: document.getElementById('edit-is-public').checked
                    };

                    try {
                        const response = await fetch('?handler=EditGroup', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: JSON.stringify(payload)
                        });
                        const result = await response.json();
                        if (result.success) {
                            showStatusMessage(result.message, true);

                            // Update the table row dynamically
                            const row = document.getElementById(`group-row-${payload.Id}`);
                            if (row) {
                                row.querySelector('td:nth-child(1)').textContent = payload.Name;
                                const publicCell = row.querySelector('td:nth-child(2)');
                                publicCell.innerHTML = payload.IsPublic
                                    ? '<i class="bi bi-check-circle-fill text-success">Public</i>'
                                    : '<i class="bi bi-x-circle-fill text-danger">Private</i>';

                                // Update the edit button's data attributes
                                const editBtn = row.querySelector('.edit-group-btn');
                                if (editBtn) {
                                    editBtn.setAttribute('data-group-name', payload.Name);
                                    editBtn.setAttribute('data-is-public', payload.IsPublic.toString());
                                }
                            }

                            // Close modal
                            bootstrap.Modal.getInstance(document.getElementById('editGroupModal')).hide();
                        } else {
                            showStatusMessage(result.message, false);
                        }
                    } catch (error) {
                        showStatusMessage("An error occurred. Please try again.", false);
                        console.error('Error editing group:', error);
                    }
                });
            }

            // Delete Button Handler
            document.querySelectorAll('.delete-group-btn').forEach(button => {
                button.addEventListener('click', async function () {
                    const groupId = this.getAttribute('data-group-id');
                    const groupName = this.getAttribute('data-group-name');
                    if (confirm(`Are you sure you want to delete group '${groupName}'? This action is irreversible.`)) {
                        try {
                            const response = await fetch(`?handler=DeleteGroup&id=${groupId}`, {
                                method: 'POST',
                                headers: {
                                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                                }
                            });
                            const result = await response.json();
                            if (result.success) {
                                showStatusMessage(result.message, true);
                                // Remove the row from the table
                                const row = document.getElementById(`group-row-${result.deletedGroupId}`);
                                if (row) {
                                    row.remove();
                                }
                            } else {
                                showStatusMessage(result.message, false);
                            }
                        } catch (error) {
                            showStatusMessage("An error occurred. Please try again.", false);
                            console.error('Error deleting group:', error);
                        }
                    }
                });
            });

            // Re-attach event listeners after creating a new group
            const groupsTable = document.getElementById('groupsTable');
            if (groupsTable) {
                const observer = new MutationObserver(mutations => {
                    mutations.forEach(mutation => {
                        if (mutation.addedNodes.length > 0) {
                            mutation.addedNodes.forEach(node => {
                                if (node.nodeType === 1 && node.matches('tr')) {
                                    const deleteBtn = node.querySelector('.delete-group-btn');
                                    if (deleteBtn) {
                                        deleteBtn.addEventListener('click', async function () {
                                            const groupId = this.getAttribute('data-group-id');
                                            const groupName = this.getAttribute('data-group-name');
                                            if (confirm(`Are you sure you want to delete group '${groupName}'? This action is irreversible.`)) {
                                                try {
                                                    const response = await fetch(`?handler=DeleteGroup&id=${groupId}`, {
                                                        method: 'POST',
                                                        headers: {
                                                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                                                        }
                                                    });
                                                    const result = await response.json();
                                                    if (result.success) {
                                                        showStatusMessage(result.message, true);
                                                        const row = document.getElementById(`group-row-${result.deletedGroupId}`);
                                                        if (row) {
                                                            row.remove();
                                                        }
                                                    } else {
                                                        showStatusMessage(result.message, false);
                                                    }
                                                } catch (error) {
                                                    showStatusMessage("An error occurred. Please try again.", false);
                                                    console.error('Error deleting group:', error);
                                                }
                                            }
                                        });
                                    }
                                }
                            });
                        }
                    });
                });

                observer.observe(groupsTable.querySelector('tbody'), { childList: true });
            }
        });
    </script>
}