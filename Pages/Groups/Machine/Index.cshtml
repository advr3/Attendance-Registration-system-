@page
@model personal_attendanse_system.Pages.Groups.Machine.IndexModel
@{
    ViewData["Title"] = "Manage Machines page";
}

<div class="container mt-4">
    <div id="statusMessageContainer"></div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">Manage Machines</h2>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createMachinesModal">
            New Machines
        </button>
    </div>

    @if (!Model.IsAdmin)
    {
        <div class="alert alert-danger" role="alert">
            You do not have the authority to manage machines.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Existing Machines</h4>
                        <form>
                            <div class="input-group">
                                <input type="text" id="searchQuery" class="form-control" placeholder="Search for members...">
                                <button class="btn btn-outline-secondary" type="button" id="searchButton">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="card-body">
                        
                        <div id="noMachinesMessage" class="alert alert-info" role="alert">
                            No machines have been created yet.
                        </div>

                        <div id="machinesTableContainer" class="table-responsive" style="@(Model.Machines.Any() ? "" : "display:none;")">
                            <table class="table table-striped table-hover" id="machinesTable">
                                <thead>
                                    <tr>
                                        <th>Machine Name</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="machinesTableBody">
                                    @foreach (var machine in Model.Machines)
                                    {
                                        <tr class="machine-row" data-machine-name="@machine.Name" data-machine-id="@machine.Id">
                                            <td>@machine.Name</td>
                                            <td>
                                                <a href="/Groups/Machine/Manage/@machine.Id" class="btn btn-sm btn-info me-2">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                                <button class="btn btn-sm btn-danger delete-btn" data-id="@machine.Id">
                                                    <i class="bi bi-trash-fill"></i> Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="createMachinesModal" tabindex="-1" aria-labelledby="createMachinesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createMachinesModalLabel">Create New Machine</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form id="createMachineForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="machineNameInput" class="form-label">Machine Name</label>
                        <input type="text" id="machineNameInput" class="form-control" />
                        <span id="nameValidation" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="createMachineBtn">Create Machine</button>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const createForm = document.getElementById('createMachineForm');
            const createMachineBtn = document.getElementById('createMachineBtn');
            const machineNameInput = document.getElementById('machineNameInput');
            const nameValidationSpan = document.getElementById('nameValidation');
            const statusMessageContainer = document.getElementById('statusMessageContainer');
            const machinesTableBody = document.getElementById('machinesTableBody');
            const noMachinesMessage = document.getElementById('noMachinesMessage');
            const machinesTableContainer = document.getElementById('machinesTableContainer');

            // Show the table if it was hidden
            if (machinesTableBody.children.length > 0) {
                machinesTableContainer.style.display = 'block';
                noMachinesMessage.style.display = 'none';
            }

            // Search functionality
            const searchInput = document.getElementById('searchQuery');
            function filterGroups() {
                const searchValue = searchInput.value.toLowerCase();
                document.querySelectorAll('.machine-row').forEach(row => {
                    const memberName = row.getAttribute('data-machine-name');
                    if (memberName.includes(searchValue)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
            searchInput.addEventListener('keyup', filterGroups);
            document.getElementById('searchButton').addEventListener('click', filterGroups);

            function showStatusMessage(message, isSuccess) {
                const alertClass = isSuccess ? 'alert-success' : 'alert-danger';
                const html = `<div class="alert ${alertClass} alert-dismissible fade show" role="alert">
                                          ${message}
                                          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                      </div>`;
                statusMessageContainer.innerHTML = html;
            }

            function addMachineToTable(machine) {
                const newRow = document.createElement('tr');
                newRow.setAttribute('data-machine-id', machine.id);
                newRow.innerHTML = `
                            <td>${machine.name}</td>
                            <td>
                                <a href="/Groups/Machine/Manage/${machine.id}" class="btn btn-sm btn-info me-2">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <button class="btn btn-sm btn-danger delete-btn" data-id="${machine.id}">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            </td>
                        `;
                machinesTableBody.appendChild(newRow);

                // Show the table if it was hidden
                if (machinesTableBody.children.length > 0) {
                    machinesTableContainer.style.display = 'block';
                    noMachinesMessage.style.display = 'none';
                }

            }

            createMachineBtn.addEventListener('click', async () => {
                const machineName = machineNameInput.value.trim();

                // Simple client-side validation
                if (machineName.length < 3) {
                    nameValidationSpan.textContent = "The Machine Name must be at least 3 characters long.";
                    return;
                }
                nameValidationSpan.textContent = "";

                const requestBody = {
                    name: machineName
                };

                try {
                    const response = await fetch('?handler=CreateMachine', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(requestBody)
                    });

                    const result = await response.json();

                    if (response.ok) {
                        showStatusMessage(result.message, true);
                        addMachineToTable({ id: result.machineId, name: result.machineName });
                        machineNameInput.value = '';
                        createForm.reset();
                    } else {
                        showStatusMessage(result.message || "An error occurred.", false);
                    }
                } catch (error) {
                    showStatusMessage("Failed to create machine. Please try again.", false);
                    console.error('Error:', error);
                }

                bootstrap.Modal.getInstance(document.getElementById('createMachinesModal')).hide();

            });

            // Handle delete button clicks using event delegation
            document.addEventListener('click', async (event) => {
                if (event.target.closest('.delete-btn')) {
                    const deleteBtn = event.target.closest('.delete-btn');
                    const machineId = deleteBtn.getAttribute('data-id');

                    if (confirm('Are you sure you want to delete this machine?')) {
                        const requestBody = {
                            id: machineId
                        };

                        try {
                            const response = await fetch('?handler=DeleteMachine',{
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                                },
                                body: JSON.stringify(requestBody)
                            });

                            const result = await response.json();

                            if (response.ok) {
                                showStatusMessage(result.message, true);
                                const row = deleteBtn.closest('tr');
                                if (row) {
                                    row.remove();
                                }

                                // Hide table if no machines are left
                                if (machinesTableBody.children.length === 0) {
                                    machinesTableContainer.style.display = 'none';
                                    noMachinesMessage.style.display = 'block';
                                }
                            } else {
                                showStatusMessage(result.message || "An error occurred during deletion.", false);
                            }
                        } catch (error) {
                            showStatusMessage("Failed to delete machine. Please try again.", false);
                            console.error('Error:', error);
                        }
                    }
                }
            });
        });
    </script>
}