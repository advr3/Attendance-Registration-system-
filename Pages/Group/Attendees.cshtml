@page "{linkId:long}"
@model personal_attendanse_system.Pages.Group.AttendeesModel
@{
}

<div class="container mt-5">
    <h1 class="mb-4">Attendees for Link</h1>
    <p class="lead">Viewing attendees for group <strong>@Model.Group.name</strong>, link created on @Model.Link.creationDate.ToLocalTime().ToString("g")</p>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><strong>Link Status:</strong> 
                @if (Model.Link.expirationDate < DateTime.UtcNow)
                {
                    <span class="badge bg-danger">Expired</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </p>
            <p><strong>Expiration Date:</strong> @Model.Link.expirationDate.ToLocalTime().ToString("g")</p>
            <p><strong>Total Attendees:</strong> @Model.Attendees.Count()</p>
        </div>
    </div>

    <hr />

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>User Name</th>
                    <th>User Email</th>
                    <th>Attendance Date</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Attendees.Any())
                {
                    @foreach (var attendee in Model.Attendees)
                    {
                        <tr>
                            <td>@attendee.User.UserName</td>
                            <td>@attendee.User.Email</td>
                            <td>@attendee.attendensDate.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">No attendees found for this link.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        <a asp-page="/Group/Index" asp-route-id="@Model.Group.Id" class="btn btn-secondary">Back to Group Dashboard</a>
    </div>
</div>
